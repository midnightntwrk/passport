+		match block_opt.zip(latest_block_opt) {
+			None => Ok(None),
+			Some((block, latest_block)) => {
+				let is_stable = block
+					.block_no
+					.saturating_add(self.security_parameter)
+					<= latest_block.block_no;
+				let in_window = self.is_block_time_valid(&block, reference_timestamp);
+				if !in_window {
+					let window_lo = self.min_block_allowed_time(reference_timestamp);
+					let window_hi = self.max_allowed_block_time(reference_timestamp);
