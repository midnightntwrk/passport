------------------------------------------------------------------------
-- Midnight.Passport.Semantics
--
-- Attaches semantics to the architecture diagram via the standard
-- "free category + interpretation functors" recipe.
--
--   * C_arch вҖ” the free strict symmetric monoidal category generated by
--     the channels `ArchChan` (objects) and the boxes `ArchBox`
--     (morphisms) of `architecture`.  `architectureб¶ң` is the architecture
--     rebuilt in this category.
--
--   * Syntax functor `syn : C_arch вҶ’ FMTerm` вҖ” the object generator map
--     `chanName : ArchChan вҶ’ String` together with `synBox` sending each
--     box to its named `gen`.  Since the objects differ (ArchChan vs
--     String) `syn` transports along `chanName` on the nose; it recovers
--     the current `architecture` term verbatim.
--
--   * Semantics generator data вҖ” each channel to a `Channel`, each
--     `ArchBox` to a `Machine`.  By the universal property of the free
--     SMC this data INDUCES a symmetric monoidal functor C_arch вҶ’ Machine
--     once the Machine category is packaged as such.  Stubs for now.
------------------------------------------------------------------------

module Midnight.Passport.Semantics where

open import Data.String using (String)
open import Data.List   using (List; []; _вҲ·_; map; _++_)
open import Data.List.Properties using (map-++)
open import Data.Unit   using (вҠӨ)
open import Relation.Binary.PropositionalEquality using (_вүЎ_; refl)

open import Categories.FreeMonoidal using (Symm; _вүӨ_; vвүӨv)
import Categories.FreeStrictMonoidal as FSM

import Midnight.Passport.FMTerm as FM

import CategoricalCrypto.Channel.Core as Ch
import CategoricalCrypto.Machine.Core as Mc

------------------------------------------------------------------------
-- 0.  Object generators: the architecture's channels
------------------------------------------------------------------------

data ArchChan : Set where
  TBD TBD-SYNC RECOVERY-P5 READ-STATE JUBJUB-SCHNORR STATE WITNESS-IPC User : ArchChan

-- The free strict SMC's object language is built over ArchChan.
module HA = FSM.FreeMonoidalHelper Symm ArchChan
open HA using (ObjTerm; _вҠ—вӮҖ_; unit; Var)

------------------------------------------------------------------------
-- 1.  Morphism generators: exactly the boxes of `architecture`
------------------------------------------------------------------------

data ArchBox : ObjTerm вҶ’ ObjTerm вҶ’ Set where
  didContract     : ArchBox unit (Var TBD)
  nameService     : ArchBox unit (Var TBD)
  peerDevices     : ArchBox unit (Var TBD-SYNC)
  recoveryHelpers : ArchBox unit (Var RECOVERY-P5)
  indexer         : ArchBox unit (Var READ-STATE)
  accountCustody  : ArchBox (Var TBD вҠ—вӮҖ Var TBD) (Var JUBJUB-SCHNORR)
  localWallet     : ArchBox (Var TBD-SYNC) (Var STATE)
  proofServer     : ArchBox unit (Var WITNESS-IPC)
  passportKey     : ArchBox
                      ( Var RECOVERY-P5 вҠ—вӮҖ Var READ-STATE вҠ—вӮҖ Var JUBJUB-SCHNORR
                      вҠ—вӮҖ Var STATE вҠ—вӮҖ Var WITNESS-IPC )
                      ( Var User )

open HA.Mor ArchBox

------------------------------------------------------------------------
-- 2.  `architecture`, rebuilt in C_arch
------------------------------------------------------------------------

opaque
  unfolding ObjTerm _вҠ—вӮҖ_ unit Var

  architectureб¶ң : HomTerm unit (Var User)
  architectureб¶ң =
      var passportKey
    вҲҳ (    var recoveryHelpers вҠ—вӮҒ var indexer вҠ—вӮҒ var accountCustody
        вҠ—вӮҒ var localWallet     вҠ—вӮҒ var proofServer )
    вҲҳ ( var didContract вҠ—вӮҒ var nameService вҠ—вӮҒ var peerDevices )

------------------------------------------------------------------------
-- 3.  Syntax functor  C_arch вҶ’ FMTerm
------------------------------------------------------------------------

chanName : ArchChan вҶ’ String
chanName TBD            = "TBD"
chanName TBD-SYNC       = "TBD SYNC"
chanName RECOVERY-P5    = "RECOVERY-P5"
chanName READ-STATE     = "READ STATE"
chanName JUBJUB-SCHNORR = "JUBJUB SCHNORR"
chanName STATE          = "STATE"
chanName WITNESS-IPC    = "WITNESS-IPC"
chanName User           = "User"

opaque
  unfolding ObjTerm _вҠ—вӮҖ_ unit Var

  ОҰ : ObjTerm вҶ’ FM.ObjTerm
  ОҰ = map chanName

  synBox : вҲҖ {A B} вҶ’ ArchBox A B вҶ’ FM.HomTerm (ОҰ A) (ОҰ B)
  synBox didContract     = FM.gen "Midnight DID contract"   FM.unit (FM.Var "TBD")
  synBox nameService     = FM.gen "Name Service"            FM.unit (FM.Var "TBD")
  synBox peerDevices     = FM.gen "+ peer devices"          FM.unit (FM.Var "TBD SYNC")
  synBox recoveryHelpers = FM.gen "Recovery helpers"        FM.unit (FM.Var "RECOVERY-P5")
  synBox indexer         = FM.gen "Indexer"                 FM.unit (FM.Var "READ STATE")
  synBox accountCustody  = FM.gen "Account custody contract"
                             (FM.Var "TBD" FM.вҠ—вӮҖ FM.Var "TBD") (FM.Var "JUBJUB SCHNORR")
  synBox localWallet     = FM.gen "Local wallet storage"    (FM.Var "TBD SYNC") (FM.Var "STATE")
  synBox proofServer     = FM.gen "Proof server"            FM.unit (FM.Var "WITNESS-IPC")
  synBox passportKey     = FM.gen "Passport Key"
                             ( FM.Var "RECOVERY-P5" FM.вҠ—вӮҖ FM.Var "READ STATE" FM.вҠ—вӮҖ FM.Var "JUBJUB SCHNORR"
                             FM.вҠ—вӮҖ FM.Var "STATE" FM.вҠ—вӮҖ FM.Var "WITNESS-IPC" )
                             ( FM.Var "User" )

  syn : вҲҖ {A B} вҶ’ HomTerm A B вҶ’ FM.HomTerm (ОҰ A) (ОҰ B)
  syn (var b)                  = synBox b
  syn id                       = FM.id
  syn (g вҲҳ f)                  = syn g FM.вҲҳ syn f
  syn (_вҠ—вӮҒ_ {A} {B} {C} {D} f g)
    rewrite map-++ chanName A C | map-++ chanName B D = syn f FM.вҠ—вӮҒ syn g
  syn О»вҮ’                       = FM.О»вҮ’
  syn О»вҮҗ                       = FM.О»вҮҗ
  syn (ПҒвҮ’ {A}) rewrite map-++ chanName A [] = FM.ПҒвҮ’
  syn (ПҒвҮҗ {A}) rewrite map-++ chanName A [] = FM.ПҒвҮҗ
  syn (ОұвҮ’ {A} {B} {C})
    rewrite map-++ chanName (A вҠ—вӮҖ B) C | map-++ chanName A B
          | map-++ chanName A (B вҠ—вӮҖ C) | map-++ chanName B C = FM.ОұвҮ’ {ОҰ A} {ОҰ B} {ОҰ C}
  syn (ОұвҮҗ {A} {B} {C})
    rewrite map-++ chanName A (B вҠ—вӮҖ C) | map-++ chanName B C
          | map-++ chanName (A вҠ—вӮҖ B) C | map-++ chanName A B = FM.ОұвҮҗ {ОҰ A} {ОҰ B} {ОҰ C}
  syn (Пғ {A} {B} вҰғ i вҰ„)
    rewrite map-++ chanName A B | map-++ chanName B A = FM.Пғ {ОҰ A} {ОҰ B} вҰғ i вҰ„

  architectureЛў : FM.HomTerm FM.unit (FM.Var "User")
  architectureЛў = syn architectureб¶ң

------------------------------------------------------------------------
-- 4.  Semantics interpretation: generators вҶ’ Machine
------------------------------------------------------------------------

-- Placeholder channel for every architecture channel.
в—Ҹ : Ch.Channel
в—Ҹ = вҠӨ Ch.вҮҝ вҠӨ

objвӮҳ : ArchChan вҶ’ Ch.Channel
objвӮҳ _ = в—Ҹ

opaque
  unfolding ObjTerm _вҠ—вӮҖ_ unit Var

  вҹҰ_вҹ§вӮҖ : ObjTerm вҶ’ Ch.Channel
  вҹҰ []     вҹ§вӮҖ = Ch.I
  вҹҰ x вҲ· xs вҹ§вӮҖ = objвӮҳ x Ch.вҠ—вӮҖ вҹҰ xs вҹ§вӮҖ

-- The chaotic stub machine: every transition is permitted.
stub : вҲҖ {A B} вҶ’ Mc.Machine A B
stub = Mc.MkMachine {State = вҠӨ} (О» _ _ _ _ вҶ’ вҠӨ)

-- Morphism-generator interpretation.
morвӮҳ : вҲҖ {A B} вҶ’ ArchBox A B вҶ’ Mc.Machine вҹҰ A вҹ§вӮҖ вҹҰ B вҹ§вӮҖ
morвӮҳ _ = stub
